{
  "name": "AgentTemplate",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "research",
        "coding",
        "analysis",
        "monitoring",
        "automation",
        "creative"
      ]
    },
    "system_prompt": {
      "type": "string"
    },
    "default_mode": {
      "type": "string",
      "enum": [
        "chat",
        "research",
        "code",
        "self_improve"
      ],
      "default": "chat"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "icon": {
      "type": "string"
    },
    "is_builtin": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "name",
    "description",
    "system_prompt"
  ]
}