{
  "name": "Memory",
  "type": "object",
  "properties": {
    "key": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "fact",
        "preference",
        "context",
        "skill",
        "self_improvement"
      ]
    },
    "importance": {
      "type": "number",
      "default": 5
    },
    "source_conversation_id": {
      "type": "string"
    }
  },
  "required": [
    "key",
    "value",
    "category"
  ]
}