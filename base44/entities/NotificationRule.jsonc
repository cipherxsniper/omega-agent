{
  "name": "NotificationRule",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "gmail",
        "github",
        "dropbox",
        "any"
      ]
    },
    "trigger_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger_sender": {
      "type": "string"
    },
    "min_priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "default": "medium"
    },
    "dedupe_key": {
      "type": "string"
    },
    "action": {
      "type": "string",
      "enum": [
        "notify",
        "summarize",
        "create_job",
        "auto_respond"
      ],
      "default": "notify"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "last_fired_at": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "source"
  ]
}