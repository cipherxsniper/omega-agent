{
  "name": "AgentStep",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "step_number": {
      "type": "number"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "completed",
        "failed"
      ],
      "default": "pending"
    },
    "tool": {
      "type": "string",
      "enum": [
        "browser",
        "terminal",
        "editor",
        "search",
        "analysis",
        "thinking",
        "none"
      ]
    },
    "tool_output": {
      "type": "string"
    },
    "tool_url": {
      "type": "string"
    },
    "duration_ms": {
      "type": "number"
    }
  },
  "required": [
    "conversation_id",
    "title"
  ]
}