{
  "name": "SandboxSession",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "active",
        "suspended",
        "error"
      ],
      "default": "idle"
    },
    "environment": {
      "type": "string",
      "default": "omega-sandbox"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_command": {
      "type": "string"
    },
    "last_output": {
      "type": "string"
    },
    "working_directory": {
      "type": "string",
      "default": "/home/omega"
    },
    "auto_execute": {
      "type": "boolean",
      "default": false
    },
    "session_log": {
      "type": "string"
    }
  },
  "required": [
    "status"
  ]
}