{
  "name": "SystemPrompt",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "default": 1
    },
    "content": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "improvement_notes": {
      "type": "string"
    },
    "performance_score": {
      "type": "number"
    }
  },
  "required": [
    "content"
  ]
}