{
  "name": "GitHubSync",
  "type": "object",
  "properties": {
    "repo_url": {
      "type": "string"
    },
    "pat_token": {
      "type": "string"
    },
    "branch": {
      "type": "string",
      "default": "main"
    },
    "auto_sync": {
      "type": "boolean",
      "default": false
    },
    "last_sync_at": {
      "type": "string"
    },
    "sync_status": {
      "type": "string",
      "enum": [
        "idle",
        "syncing",
        "success",
        "error"
      ],
      "default": "idle"
    },
    "error_message": {
      "type": "string"
    }
  },
  "required": [
    "repo_url",
    "pat_token"
  ]
}