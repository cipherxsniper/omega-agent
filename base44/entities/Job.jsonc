{
  "name": "Job",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed"
      ],
      "default": "queued"
    },
    "type": {
      "type": "string",
      "enum": [
        "research",
        "code_gen",
        "self_improve",
        "sync",
        "analysis",
        "custom"
      ]
    },
    "conversation_id": {
      "type": "string"
    },
    "input_data": {
      "type": "string"
    },
    "output_data": {
      "type": "string"
    },
    "progress": {
      "type": "number",
      "default": 0
    },
    "error_message": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "type"
  ]
}