{
  "name": "Event",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "enum": [
        "gmail",
        "github",
        "dropbox",
        "agent",
        "system",
        "user"
      ]
    },
    "source_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "sender": {
          "type": "string"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priority": {
          "type": "string"
        }
      }
    },
    "related_event_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "correlation_score": {
      "type": "number"
    },
    "correlation_status": {
      "type": "string",
      "enum": [
        "none",
        "auto_linked",
        "possibly_related",
        "confirmed",
        "rejected"
      ],
      "default": "none"
    },
    "processed": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "source",
    "title"
  ]
}