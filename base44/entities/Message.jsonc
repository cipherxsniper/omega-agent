{
  "name": "Message",
  "type": "object",
  "properties": {
    "conversation_id": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant",
        "system"
      ]
    },
    "content": {
      "type": "string"
    },
    "reasoning_chain": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          }
        }
      }
    },
    "job_id": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string"
        },
        "tokens_used": {
          "type": "number"
        },
        "response_time_ms": {
          "type": "number"
        },
        "mode": {
          "type": "string",
          "enum": [
            "chat",
            "research",
            "code",
            "self_improve"
          ]
        }
      }
    }
  },
  "required": [
    "conversation_id",
    "role",
    "content"
  ]
}