{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active"
    },
    "message_count": {
      "type": "number",
      "default": 0
    },
    "last_message_preview": {
      "type": "string"
    },
    "model_version": {
      "type": "string",
      "default": "omega-1.0"
    }
  },
  "required": [
    "title"
  ]
}